#!/bin/bash
# ╔═══════════════════════════════════════════════════════════════════╗
# ║                        SumiNami Bar                               ║
# ║              Style Generator / Configuration Loader               ║
# ╚═══════════════════════════════════════════════════════════════════╝
# Called at waybar startup to adapt to display and apply configuration

WAYBAR_DIR="$HOME/.config/waybar"
CONFIG_FILE="$WAYBAR_DIR/suminami.conf"
STYLE_FILE="$WAYBAR_DIR/style.css"
SCALE_FILE="$WAYBAR_DIR/scale.css"
ROFI_DIR="$HOME/.config/rofi"

# ─────────────────────────────────────────────────────────────────────
# Read configuration
# ─────────────────────────────────────────────────────────────────────
get_config() {
    local key="$1"
    local default="$2"
    if [ -f "$CONFIG_FILE" ]; then
        value=$(grep "^${key}=" "$CONFIG_FILE" 2>/dev/null | cut -d'=' -f2 | tr -d ' ')
        [ -n "$value" ] && echo "$value" || echo "$default"
    else
        echo "$default"
    fi
}

# Load config values
color_scheme=$(get_config "color_scheme" "kanagawa")
module_taskbar=$(get_config "module_taskbar" "false")
module_media=$(get_config "module_media" "true")
module_weather=$(get_config "module_weather" "true")
module_bluetooth=$(get_config "module_bluetooth" "true")
module_backlight=$(get_config "module_backlight" "true")
tooltip_delay=$(get_config "tooltip_delay" "200")

# Font weight - 700 for better readability across all themes
font_weight="700"

# Detect light themes (for other adjustments)
# Use space-delimited match to avoid partial matches (e.g., kanagawa vs kanagawa-lotus)
light_themes=" kanagawa-lotus catppuccin-latte "
if [[ "$light_themes" == *" $color_scheme "* ]]; then
    is_light_theme="true"
else
    is_light_theme="false"
fi

# Verify color scheme exists, fallback to kanagawa
color_file="colors/${color_scheme}.css"
if [ ! -f "$WAYBAR_DIR/$color_file" ]; then
    echo "Warning: Color scheme '$color_scheme' not found, falling back to kanagawa" >&2
    color_scheme="kanagawa"
    color_file="colors/kanagawa.css"
    font_weight="500"
fi

# ─────────────────────────────────────────────────────────────────────
# Detect screen resolution
# ─────────────────────────────────────────────────────────────────────
get_logical_width() {
    # Try Hyprland first — use logical width (physical / scale)
    # This ensures the tier system accounts for compositor scaling
    if command -v hyprctl &>/dev/null; then
        local info
        info=$(hyprctl monitors -j 2>/dev/null)
        if [ -n "$info" ]; then
            local phys_width scale
            phys_width=$(echo "$info" | grep -oP '"width":\s*\K\d+' | head -1)
            scale=$(echo "$info" | grep -oP '"scale":\s*\K[0-9.]+' | head -1)
            if [ -n "$phys_width" ] && [ -n "$scale" ]; then
                awk "BEGIN { printf \"%.0f\", $phys_width / $scale }"
                return
            fi
            [ -n "$phys_width" ] && echo "$phys_width" && return
        fi
    fi

    # Try wlr-randr (Sway, etc.) — no scale info, use raw
    if command -v wlr-randr &>/dev/null; then
        width=$(wlr-randr 2>/dev/null | grep -oP '\d+x\d+' | head -1 | cut -dx -f1)
        [ -n "$width" ] && echo "$width" && return
    fi

    # Try xrandr (X11 fallback) — no scale info, use raw
    if command -v xrandr &>/dev/null; then
        width=$(xrandr 2>/dev/null | grep '\*' | head -1 | awk '{print $1}' | cut -dx -f1)
        [ -n "$width" ] && echo "$width" && return
    fi

    echo "1920"
}

width=$(get_logical_width)

# ─────────────────────────────────────────────────────────────────────
# Resolution scaling tiers
# ─────────────────────────────────────────────────────────────────────
if [ "$width" -lt 1600 ]; then
    tier="small"
    font_size="11px"
    bar_height="38"
    icon_size="14"
    launcher_size="14px"
    launcher_padding="0 12px 0 16px"
    rofi_font="11"
elif [ "$width" -lt 1920 ]; then
    tier="medium"
    font_size="12px"
    bar_height="42"
    icon_size="15"
    launcher_size="16px"
    launcher_padding="0 14px 0 18px"
    rofi_font="12"
elif [ "$width" -lt 2560 ]; then
    tier="large"
    font_size="13px"
    bar_height="46"
    icon_size="16"
    launcher_size="18px"
    launcher_padding="0 14px 0 20px"
    rofi_font="13"
else
    tier="xlarge"
    font_size="14px"
    bar_height="50"
    icon_size="18"
    launcher_size="20px"
    launcher_padding="0 16px 0 22px"
    rofi_font="14"
fi

# ─────────────────────────────────────────────────────────────────────
# Apply color scheme to style.css
# ─────────────────────────────────────────────────────────────────────
color_file="colors/${color_scheme}.css"
if [ -f "$WAYBAR_DIR/$color_file" ]; then
    # Update the @import in style.css
    sed -i "s|@import \"colors/[^\"]*\"|@import \"$color_file\"|" "$STYLE_FILE"
fi

# ─────────────────────────────────────────────────────────────────────
# Parse color values from CSS file (needed for scale.css and other configs)
# ─────────────────────────────────────────────────────────────────────
get_color() {
    local var="$1"
    grep "@define-color $var" "$WAYBAR_DIR/$color_file" 2>/dev/null | grep -oP '#[0-9A-Fa-f]{6}' | head -1
}

# Get key colors from the scheme
bg_color=$(get_color "sumiInk0") || bg_color="#16161D"
bg_light=$(get_color "sumiInk3") || bg_light="#363646"
fg_color=$(get_color "fujiWhite") || fg_color="#DCD7BA"
accent=$(get_color "sakuraPink") || accent="#D27E99"
border=$(get_color "sumiInk5") || border="#363646"

# ─────────────────────────────────────────────────────────────────────
# Generate scale.css
# ─────────────────────────────────────────────────────────────────────

# Waybar and tooltip opacity (96%)
bar_bg="alpha(@sumiInk0, 0.96)"
tooltip_bg="alpha(${bg_color}, 0.96)"

cat > "$SCALE_FILE" << EOF
/* SumiNami Bar - Auto-generated for ${width}px logical ($tier tier) */
/* Color scheme: $color_scheme */

*,
label {
    font-size: $font_size;
    font-weight: $font_weight;
}

#custom-launcher {
    font-size: $launcher_size;
    padding: $launcher_padding;
}

/* Theme-specific background opacity */
window#waybar {
    background-color: ${bar_bg};
}

/* Tooltip colors */
window tooltip,
window#waybar tooltip {
    background-color: ${tooltip_bg};
    border-color: #dddddd;
}

window tooltip label,
window#waybar tooltip label {
    color: ${fg_color};
}
EOF

# ─────────────────────────────────────────────────────────────────────
# Update waybar config.jsonc (height/icon-size only - colors done later)
# ─────────────────────────────────────────────────────────────────────
sed -i "s/\"height\": [0-9]*/\"height\": $bar_height/" "$WAYBAR_DIR/config.jsonc"
sed -i "s/\"icon-size\": [0-9]*/\"icon-size\": $icon_size/" "$WAYBAR_DIR/config.jsonc"

# ─────────────────────────────────────────────────────────────────────
# Generate rofi config and theme
# ─────────────────────────────────────────────────────────────────────
mkdir -p "$ROFI_DIR"

# Get additional colors for rofi
bg_hover=$(get_color "sumiInk4") || bg_hover="#2A2A37"
muted=$(get_color "sumiInk6") || muted="#54546D"
accent_color=$(get_color "module-clock") || accent_color="$accent"
error_color=$(get_color "state-critical") || error_color="#E82424"

# Main config
cat > "$ROFI_DIR/config.rasi" << EOF
/* Rofi config - SumiNami */
/* Auto-generated for ${width}px logical ($tier tier) */
configuration {
    modi: "drun,run";
    show-icons: true;
    icon-theme: "Papirus";
    terminal: "kitty";
    font: "JetBrainsMono Nerd Font ${rofi_font}";
    drun-display-format: "{name}";
    disable-history: false;
    sidebar-mode: false;
    cycle: true;
    click-to-exit: true;
    hover-select: true;
    me-select-entry: "";
    me-accept-entry: "MousePrimary";
}

@theme "suminami"
EOF

# Convert hex to rgba for 96% opacity background
bg_hex="${bg_color#\#}"
bg_r=$((16#${bg_hex:0:2}))
bg_g=$((16#${bg_hex:2:2}))
bg_b=$((16#${bg_hex:4:2}))

# Theme file
cat > "$ROFI_DIR/suminami.rasi" << EOF
/* SumiNami Rofi Theme - $color_scheme */
/* Auto-generated for ${width}px logical ($tier tier) */

* {
    bg:           rgba($bg_r, $bg_g, $bg_b, 96%);
    bg-alt:       $bg_hover;
    fg:           $fg_color;
    fg-alt:       $muted;
    accent:       $accent_color;
    urgent:       $error_color;
    border-grey:  #dddddd;

    background-color: transparent;
    text-color: @fg;
    margin: 0;
    padding: 0;
    spacing: 0;
}

window {
    background-color: @bg;
    border: 1px;
    border-color: @border-grey;
    border-radius: 0;
    width: 450px;
    padding: 12px;
}

mainbox {
    children: [inputbar, listview];
    spacing: 8px;
}

inputbar {
    background-color: @bg-alt;
    border: 1px;
    border-color: @border-grey;
    border-radius: 0;
    padding: 8px 12px;
    children: [prompt, entry];
    spacing: 8px;
}

prompt {
    text-color: @accent;
}

entry {
    placeholder: "Search...";
    placeholder-color: @fg-alt;
}

listview {
    lines: 8;
    columns: 1;
    fixed-height: false;
    scrollbar: false;
    spacing: 2px;
}

element {
    padding: 8px 14px;
    border-radius: 0;
    spacing: 8px;
}

element normal.normal {
    background-color: transparent;
}

element normal.urgent {
    text-color: @urgent;
}

element normal.active {
    text-color: @accent;
}

element selected.normal {
    background-color: rgba($bg_r, $bg_g, $bg_b, 50%);
    text-color: @accent;
}

element selected.urgent {
    background-color: @urgent;
    text-color: @bg;
}

element selected.active {
    background-color: @accent;
    text-color: @bg;
}

element-icon {
    size: 24px;
}

element-text {
    text-color: inherit;
    vertical-align: 0.5;
}
EOF

# ─────────────────────────────────────────────────────────────────────
# Update GTK tooltip delay
# ─────────────────────────────────────────────────────────────────────
mkdir -p "$HOME/.config/gtk-3.0"
if [ -f "$HOME/.config/gtk-3.0/settings.ini" ]; then
    if grep -q "gtk-tooltip-timeout" "$HOME/.config/gtk-3.0/settings.ini"; then
        sed -i "s/gtk-tooltip-timeout=.*/gtk-tooltip-timeout=$tooltip_delay/" "$HOME/.config/gtk-3.0/settings.ini"
    else
        echo "gtk-tooltip-timeout=$tooltip_delay" >> "$HOME/.config/gtk-3.0/settings.ini"
    fi
else
    cat > "$HOME/.config/gtk-3.0/settings.ini" << EOF
[Settings]
gtk-tooltip-timeout=$tooltip_delay
EOF
fi

# ─────────────────────────────────────────────────────────────────────
# Generate colors.sh for scripts to source
# ─────────────────────────────────────────────────────────────────────
COLORS_FILE="$WAYBAR_DIR/scripts/colors.sh"

# Get all semantic colors for tooltips
tooltip_accent=$(get_color "module-clock") || tooltip_accent="#D27E99"
tooltip_system=$(get_color "module-system") || tooltip_system="#98BB6C"
tooltip_weather=$(get_color "module-weather") || tooltip_weather="#A3D4D5"
tooltip_network=$(get_color "module-network") || tooltip_network="#957FB8"
tooltip_audio=$(get_color "module-audio") || tooltip_audio="#7FB4CA"
tooltip_muted=$(get_color "module-muted") || tooltip_muted="#727169"
tooltip_warning=$(get_color "state-warning") || tooltip_warning="#E6C384"
tooltip_critical=$(get_color "state-critical") || tooltip_critical="#E46876"

# Highlight color for tooltip values (pink for blossom, blue for others)
if [ "$color_scheme" = "kanagawa-blossom" ]; then
    tooltip_highlight="#F4A7B9"
else
    tooltip_highlight="$tooltip_audio"
fi

cat > "$COLORS_FILE" << EOF
#!/bin/bash
# SumiNami Bar - Theme colors for scripts
# Auto-generated for: $color_scheme
# DO NOT EDIT - regenerated by generate-style

# Theme info
THEME_NAME="$color_scheme"
THEME_IS_LIGHT="$is_light_theme"

# Background colors
COLOR_BG="$bg_color"
COLOR_BG_LIGHT="$bg_light"
COLOR_BORDER="$border"

# Foreground colors
COLOR_FG="$fg_color"
COLOR_MUTED="$tooltip_muted"

# Accent colors (WCAG compliant)
COLOR_ACCENT="$tooltip_accent"
COLOR_SYSTEM="$tooltip_system"
COLOR_WEATHER="$tooltip_weather"
COLOR_NETWORK="$tooltip_network"
COLOR_AUDIO="$tooltip_audio"
COLOR_HIGHLIGHT="$tooltip_highlight"

# State colors
COLOR_WARNING="$tooltip_warning"
COLOR_CRITICAL="$tooltip_critical"
EOF

chmod +x "$COLORS_FILE"

# ─────────────────────────────────────────────────────────────────────
# Update clock calendar colors in config.jsonc (now that colors are defined)
# ─────────────────────────────────────────────────────────────────────
sed -i "s|\"months\": \"<span color='[^']*'|\"months\": \"<span color='$fg_color'|g" "$WAYBAR_DIR/config.jsonc"
sed -i "s|\"weeks\": \"<span color='[^']*'|\"weeks\": \"<span color='$tooltip_muted'|g" "$WAYBAR_DIR/config.jsonc"
sed -i "s|\"weekdays\": \"<span color='[^']*'|\"weekdays\": \"<span color='$tooltip_accent'|g" "$WAYBAR_DIR/config.jsonc"
sed -i "s|\"days\": \"<span color='[^']*'|\"days\": \"<span color='$tooltip_muted'|g" "$WAYBAR_DIR/config.jsonc"
sed -i "s|\"today\": \"<span color='[^']*'|\"today\": \"<span color='$tooltip_accent'|g" "$WAYBAR_DIR/config.jsonc"

echo "$tier:$color_scheme:$bar_height"
