#!/bin/bash
# Application launcher - toggle behavior
# If rofi is running, close it. Otherwise, launch it.

# Check if rofi is already running
if pgrep -x rofi > /dev/null; then
    # Rofi is running - kill it (toggle OFF)
    pkill -x rofi
    exit 0
fi

# Rofi is not running - launch it (toggle ON)
CONFIG_FILE="$HOME/.config/waybar/suminami.conf"

# Get launcher command from config, default to hub menu
launcher_cmd="$HOME/.config/suminami/scripts/hub/hub.sh"
if [ -f "$CONFIG_FILE" ]; then
    configured=$(grep "^launcher_command=" "$CONFIG_FILE" | cut -d'=' -f2-)
    if [ -n "$configured" ]; then
        # Expand ~ and $HOME in the command
        configured="${configured/#\~/$HOME}"
        configured="${configured//\$HOME/$HOME}"
        launcher_cmd="$configured"
    fi
fi

exec $launcher_cmd
